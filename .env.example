# 复制为 .env 后按需填写：cp .env.example .env
# 切勿把真实密钥提交到 git

# ==================== AI 大模型 ====================
OPENAI_BASE_URL=http://127.0.0.1:1234/v1
OPENAI_API_KEY=
OPENAI_BASE_MODEL=qwen/qwen3-8b

DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=
# DEEPSEEK_BASE_MODEL=

# MinerU（可选）
# MINERU_API_KEY=

# ==================== 数据源 ====================
# 通达信本地 tq 代理（仅 Windows + 已安装通达信客户端；macOS/Linux 请保持 false）
TDX_QUANT_ENABLED=false
TDX_ROOT=E:\Program\tdx
# TDX_PYPLUGINS_USER=
# TDX_DLL_PATH=
# ETL 经 HTTP 调用本 API 的通达信中转
# TDX_API_HOST=localhost
# TDX_API_PORT=8000
# TDX_API_TIMEOUT=300

# Tushare：official（官方）/ stocktoday（第三方镜像）
TUSHARE_CHANNEL=official
# stocktoday 自签证书时需 false
TUSHARE_SSL_VERIFY=true
TUSHARE_API_KEY=
TUSHARE_API_URL=http://api.waditu.com/dataapi
TUSHARE_STOCKTODAY_API_KEY=
TUSHARE_STOCKTODAY_API_URL=https://tushare.citydata.club/dataapi
TUSHARE_TIMEOUT=30
TUSHARE_RETRY_COUNT=3
# TUSHARE_RETRY_INTERVAL=3
# TUSHARE_MAX_QPS=450

# ==================== 数据库 ====================
POSTGRESQL_HOST=localhost
POSTGRESQL_PORT=5432
POSTGRESQL_USER=postgres
POSTGRESQL_PASSWORD=
POSTGRESQL_DATABASE=quantus
POSTGRESQL_ECHO=false
POSTGRESQL_POOL_SIZE=10
POSTGRESQL_MAX_OVERFLOW=20

# TimescaleDB（若与主库分离时使用；当前可与 PG 同实例）
# TIMESCALE_HOST=localhost
# TIMESCALE_PORT=5432
# TIMESCALE_USER=postgres
# TIMESCALE_PASSWORD=
# TIMESCALE_DB_NAME=quantus
# TIMESCALE_ECHO=false

# ==================== API / 调度 ====================
# SCHEDULER_ENABLED=true

# Admin SSE 补位最大并行数（根目录 .env；Vite 读取，改后需重启 pnpm dev）
VITE_ETL_SSE_MAX_CONCURRENT=5

# ==================== 仓库 ====================
# WAREHOUSE_ROOT=./data/warehouse

# ==================== ETL 增量起点 ====================
# 未单独配置的表 → ETL_DEFAULT_START_DATE
# 单独配置：{DB表名大写}_START_DATE=YYYYMMDD
# 按月增量：{DB表名大写}_START_MONTH=YYYYMM（目前仅 index_weight）
ETL_DEFAULT_START_DATE=19901219
# KLINE_DAILY_START_DATE=19901219
# KLINE_ADJ_FACTOR_START_DATE=19901219
# STOCK_TRADE_CALENDAR_START_DATE=19901219
# FINANCIAL_REPORT_START_DATE=19901219
# STOCK_SUSPEND_START_DATE=19901219
# KLINE_STK_LIMIT_START_DATE 未设时默认 20090601（创业板开板）

# ==================== 数据源优先级（逗号分隔）====================
# KLINE_DAILY_SOURCES=tdx_quant,tushare
KLINE_DAILY_BY_DATE_SOURCES=tushare,tdx_quant
# KLINE_ADJ_FACTOR_SOURCES=tushare
# KLINE_ADJ_FACTOR_BY_DATE_SOURCES=tushare
# KLINE_STK_LIMIT_SOURCES=tushare
# KLINE_STK_LIMIT_BY_DATE_SOURCES=tushare
# REPORT_INCOME_SOURCES=tushare
# REPORT_BALANCE_SOURCES=tushare
# REPORT_CASHFLOW_SOURCES=tushare
# REPORT_INDICATOR_SOURCES=tushare
# STOCK_LIST_SOURCES=tushare
